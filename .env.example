RG_PORT=8080
RG_DB_URL=jdbc:h2:file:./data/reconcileguard;MODE=Oracle;DATABASE_TO_UPPER=false
RG_DB_USERNAME=sa
RG_DB_PASSWORD=
RG_DB_DRIVER=org.h2.Driver
RG_JWT_SECRET=replace-this-secret-with-at-least-32-bytes
RG_ADMIN_PASSWORD=replace-this-admin-password
RG_TOKEN_TTL_MINUTES=480
RG_RATE_LIMIT_PER_MINUTE=120

# Legacy no-dependency runner still supports these local-demo variables.
RG_HOST=127.0.0.1
RG_API_TOKEN=change-this-token-before-deploy
RG_DATA_DIR=data
RG_LOG_DIR=data/logs
RG_WORKERS=8
RG_MAX_REQUEST_BYTES=16384
